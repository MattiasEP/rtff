#!/usr/bin/env bash

set -euo pipefail

if [ -t 1 ]; then
  C_RESET="$(printf '\033[0m')"
  C_RED="$(printf '\033[1;31m')"
  C_YELLOW="$(printf '\033[1;33m')"
  C_GREEN="$(printf '\033[1;32m')"
  C_MAGENTA="$(printf '\033[1;35m')"
  C_CYAN="$(printf '\033[1;36m')"
  C_ORANGE="$(printf '\033[38;5;208m')"
  C_HOT_PINK="$(printf '\033[38;5;198m')"
else
  C_RESET=""
  C_RED=""
  C_YELLOW=""
  C_GREEN=""
  C_MAGENTA=""
  C_CYAN=""
  C_ORANGE=""
  C_HOT_PINK=""
fi

banner() {
  echo "${C_RED}🔥🔥🔥══════════════════════════════════════════════🔥🔥🔥${C_RESET}"
  echo "${C_RED}🔥  ${C_ORANGE}R${C_YELLOW}E${C_GREEN}L${C_CYAN}E${C_MAGENTA}A${C_HOT_PINK}S${C_RED}E ${C_ORANGE}T${C_YELLOW}H${C_GREEN}E ${C_CYAN}F${C_MAGENTA}U${C_HOT_PINK}C${C_RED}K${C_ORANGE}I${C_YELLOW}N${C_GREEN}G${C_CYAN} ${C_MAGENTA}F${C_HOT_PINK}U${C_RED}R${C_ORANGE}Y${C_RED}  🔥${C_RESET}"
  echo "${C_MAGENTA}⚡ RTFF - SHRED. TAG. DOMINATE. ⚡${C_RESET}"
  echo "${C_YELLOW}🎸 \"How can less be more? More is more!\" 🎸${C_RESET}"
  echo "${C_RED}🔥🔥🔥══════════════════════════════════════════════🔥🔥🔥${C_RESET}"
}

say() {
  echo "${C_CYAN}$*${C_RESET}"
}

shout_success() {
  echo "${C_GREEN}$*${C_RESET}"
}

shout_error() {
  echo "${C_RED}$*${C_RESET}" >&2
}

create_first_commit_if_needed() {
  local commit_message

  if git rev-parse --verify HEAD >/dev/null 2>&1; then
    return 0
  fi

  say "🧨 This repository has no commits yet."
  if ! prompt_yes_no "Create the first commit now"; then
    return 1
  fi

  read -r -p "${C_MAGENTA}📝 Commit message${C_RESET} [Initial commit]: " commit_message
  commit_message="${commit_message:-Initial commit}"

  git add -A
  git commit --allow-empty -m "${commit_message}" >/dev/null
  shout_success "⚔️ First commit created: ${commit_message}"
  return 0
}

prompt_yes_no() {
  local prompt="$1"
  local answer

  while true; do
    read -r -p "${C_MAGENTA}🤘 ${prompt} [y/n]${C_RESET}: " answer
    case "${answer}" in
      y|Y) return 0 ;;
      n|N) return 1 ;;
      *) say "🤘 Only y or n survives this solo." ;;
    esac
  done
}

select_bump_type() {
  local options=("major" "minor" "patch")
  local labels=("💀 MAJOR - apocalyptic leap" "⚡ MINOR - thunderous rise" "🔥 PATCH - razor edge tweak")
  local idx=0
  local key
  local i
  local total="${#options[@]}"
  local prompt="🎛️ Choose your release mode (use up/down and Enter):"

  SELECTED_BUMP_TYPE=""

  if [ ! -t 0 ]; then
    say "${prompt}"
    PS3="🎚️ Choice: "
    select key in "${labels[@]}"; do
      if [ -n "${key:-}" ]; then
        SELECTED_BUMP_TYPE="${options[$((REPLY - 1))]}"
        return 0
      fi
      say "🔥 Invalid selection."
    done
  fi

  say "${prompt}"
  while true; do
    for ((i = 0; i < total; i++)); do
      if [ "${i}" -eq "${idx}" ]; then
        printf "${C_YELLOW}▶ %s${C_RESET}\n" "${labels[$i]}"
      else
        printf "  %s\n" "${labels[$i]}"
      fi
    done

    IFS= read -r -s -n 1 key
    if [ "${key}" = $'\x1b' ]; then
      IFS= read -r -s -n 2 key
      case "${key}" in
        "[A") idx=$(((idx - 1 + total) % total)) ;;
        "[B") idx=$(((idx + 1) % total)) ;;
      esac
    elif [ -z "${key}" ]; then
      SELECTED_BUMP_TYPE="${options[$idx]}"
      printf "\033[%sA" "${total}"
      for ((i = 0; i < total; i++)); do
        printf "\033[2K\n"
      done
      printf "\033[%sA" "${total}"
      shout_success "🔥 Selected: ${SELECTED_BUMP_TYPE}"
      return 0
    elif [ "${key}" = "q" ] || [ "${key}" = "Q" ]; then
      printf "\033[%sA" "${total}"
      for ((i = 0; i < total; i++)); do
        printf "\033[2K\n"
      done
      printf "\033[%sA" "${total}"
      say "🛑 Selection cancelled."
      return 1
    fi

    printf "\033[%sA" "${total}"
  done
}

if ! command -v git >/dev/null 2>&1; then
  shout_error "💥 Error: git is not installed."
  exit 1
fi

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  shout_error "💥 Error: not inside a git repository."
  exit 1
fi

banner

if ! create_first_commit_if_needed; then
  shout_error "💥 Error: first commit is required before tagging."
  exit 1
fi

latest_tag="$(git tag --sort=-creatordate | sed -n '1p')"

if [ -z "${latest_tag}" ]; then
  say "📭 No tags found in this repository."

  if ! prompt_yes_no "No riffs yet. Forge the first tag"; then
    exit 0
  fi

  if ! select_bump_type; then
    exit 0
  fi
  bump_type="${SELECTED_BUMP_TYPE}"
  case "${bump_type}" in
    major) new_tag="1.0.0" ;;
    minor) new_tag="0.1.0" ;;
    patch) new_tag="0.0.1" ;;
  esac

  say "🔥 First tag queued: ${new_tag}"
  if ! prompt_yes_no "Release ${new_tag} now"; then
    exit 0
  fi

  git tag "${new_tag}"
  shout_success "🚀 Tag unleashed: ${new_tag}"
  exit 0
fi

say "🎤 Latest tag on stage: ${latest_tag}"

if ! prompt_yes_no "Bump this tag and release the fury"; then
  exit 0
fi

tag_prefix=""
tag_version="${latest_tag}"
if [[ "${latest_tag}" =~ ^([^0-9]*)([0-9]+\.[0-9]+\.[0-9]+)$ ]]; then
  tag_prefix="${BASH_REMATCH[1]}"
  tag_version="${BASH_REMATCH[2]}"
fi

if [[ ! "${tag_version}" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
  shout_error "💥 Error: latest tag is not semver-like (expected e.g. v1.2.3)."
  exit 1
fi

IFS='.' read -r major minor patch <<< "${tag_version}"

if ! select_bump_type; then
  exit 0
fi
bump_type="${SELECTED_BUMP_TYPE}"
case "${bump_type}" in
  major)
    major=$((major + 1))
    minor=0
    patch=0
    ;;
  minor)
    minor=$((minor + 1))
    patch=0
    ;;
  patch)
    patch=$((patch + 1))
    ;;
esac

new_tag="${tag_prefix}${major}.${minor}.${patch}"
say "🛠️ Next tag forged: ${new_tag}"

if ! prompt_yes_no "Release ${new_tag} now"; then
  exit 0
fi

if git rev-parse "${new_tag}" >/dev/null 2>&1; then
  shout_error "💥 Error: tag ${new_tag} already exists."
  exit 1
fi

git tag "${new_tag}"
shout_success "🚀 Tag unleashed: ${new_tag}"
