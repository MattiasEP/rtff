#!/usr/bin/env bash

set -euo pipefail

print_help() {
  cat <<'EOF'
RTFF - Release The Fucking Fury

Usage:
  rtff
  rtff --help

What it does:
  - Finds latest semver tag
  - Lets you bump major/minor/patch interactively
  - Optional annotated tag message (or lightweight tag)
  - Creates and optionally pushes the new tag

Environment:
  NO_COLOR  Set (any value) to disable ANSI colors (see https://no-color.org/)
EOF
}

if [ -t 1 ] && [ -z "${NO_COLOR+x}" ]; then
  C_RESET="$(printf '\033[0m')"
  C_RED="$(printf '\033[1;31m')"
  C_YELLOW="$(printf '\033[1;33m')"
  C_GREEN="$(printf '\033[1;32m')"
  C_MAGENTA="$(printf '\033[1;35m')"
  C_CYAN="$(printf '\033[1;36m')"
  C_ORANGE="$(printf '\033[38;5;208m')"
  C_HOT_PINK="$(printf '\033[38;5;198m')"
else
  C_RESET=""
  C_RED=""
  C_YELLOW=""
  C_GREEN=""
  C_MAGENTA=""
  C_CYAN=""
  C_ORANGE=""
  C_HOT_PINK=""
fi

if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
  print_help
  exit 0
fi

banner() {
  local width=56
  local line
  local clean
  local pad

  center_line() {
    line="$1"
    clean="$(printf "%s" "${line}" | sed -E 's/\x1B\[[0-9;]*m//g')"
    pad=$(( (width - ${#clean}) / 2 ))
    if [ "${pad}" -lt 0 ]; then
      pad=0
    fi
    printf "%*s%s${C_RESET}\n" "${pad}" "" "${line}"
  }

  center_line "${C_RED}🔥🔥🔥════════════════════════════════════════🔥🔥🔥"
  center_line "${C_RED}🔥  ${C_ORANGE}R${C_YELLOW}E${C_GREEN}L${C_CYAN}E${C_MAGENTA}A${C_HOT_PINK}S${C_RED}E ${C_ORANGE}T${C_YELLOW}H${C_GREEN}E ${C_CYAN}F${C_MAGENTA}U${C_HOT_PINK}C${C_RED}K${C_ORANGE}I${C_YELLOW}N${C_GREEN}G${C_CYAN} ${C_MAGENTA}F${C_HOT_PINK}U${C_RED}R${C_ORANGE}Y${C_RED}  🔥"
  center_line "${C_MAGENTA}⚡ RTFF - SHRED. TAG. FUCKING DOMINATE. ⚡"
  center_line "${C_YELLOW}🎸 \"How can less be more? More is more!\" - Yngwie Malmsteen 🎸"
  center_line "${C_RED}🔥🔥🔥════════════════════════════════════════🔥🔥🔥"
}

say() {
  echo "${C_CYAN}$*${C_RESET}"
}

say_release_goodbye() {
  echo "${C_YELLOW}✈️ See you in Tokyo, bitch!${C_RESET}"
}

shout_success() {
  echo "${C_GREEN}$*${C_RESET}"
}

shout_error() {
  echo "${C_RED}$*${C_RESET}" >&2
}

# Caller sets MENU_LABELS and MENU_VALUES (same length). On success sets MENU_SELECTED.
arrow_menu_interactive() {
  local prompt="$1"
  local idx="$2"
  local success_fmt="$3"
  local cancel_msg="$4"
  local total="${#MENU_LABELS[@]}"
  local i
  local key

  MENU_SELECTED=""
  if [ "${total}" -eq 0 ] || [ "${#MENU_VALUES[@]}" -ne "${total}" ]; then
    return 1
  fi

  say "${prompt}"
  while true; do
    for ((i = 0; i < total; i++)); do
      if [ "${i}" -eq "${idx}" ]; then
        printf "${C_YELLOW}▶ %s${C_RESET}\n" "${MENU_LABELS[$i]}"
      else
        printf "  %s\n" "${MENU_LABELS[$i]}"
      fi
    done

    IFS= read -r -s -n 1 key
    if [ "${key}" = $'\x1b' ]; then
      IFS= read -r -s -n 2 key
      case "${key}" in
        "[A") idx=$(((idx - 1 + total) % total)) ;;
        "[B") idx=$(((idx + 1) % total)) ;;
      esac
    elif [ -z "${key}" ]; then
      MENU_SELECTED="${MENU_VALUES[$idx]}"
      printf "\033[%sA" "${total}"
      for ((i = 0; i < total; i++)); do
        printf "\033[2K\n"
      done
      printf "\033[%sA" "${total}"
      # success_fmt is always one %s; avoid SC2059 (variable as printf format)
      shout_success "${success_fmt//%s/${MENU_SELECTED}}"
      return 0
    elif [ "${key}" = "q" ] || [ "${key}" = "Q" ]; then
      printf "\033[%sA" "${total}"
      for ((i = 0; i < total; i++)); do
        printf "\033[2K\n"
      done
      printf "\033[%sA" "${total}"
      say "${cancel_msg}"
      return 1
    fi

    printf "\033[%sA" "${total}"
  done
}

read_tag_message() {
  TAG_MESSAGE=""
  if [ ! -t 0 ]; then
    return 0
  fi
  read -r -p "${C_MAGENTA}📝 Tag message${C_RESET} (optional, Enter for lightweight tag): " TAG_MESSAGE
}

create_git_tag() {
  local name="$1"
  local msg="${2-}"
  if [ -n "${msg}" ]; then
    git tag -a "${name}" -F - <<< "${msg}"
  else
    git tag "${name}"
  fi
}

get_latest_semver_tag() {
  local tag
  while IFS= read -r tag; do
    if [[ "${tag}" =~ ^([^0-9]*)([0-9]+\.[0-9]+\.[0-9]+)$ ]]; then
      echo "${tag}"
      return 0
    fi
  done < <(git tag --sort=-v:refname)
  return 1
}

add_remote_interactive() {
  local name
  local url

  if [ ! -t 0 ]; then
    return 1
  fi

  if ! prompt_yes_no "Add a remote now (name + URL)"; then
    return 1
  fi

  read -r -p "${C_MAGENTA}Remote name${C_RESET} [origin]: " name
  name="${name:-origin}"

  while true; do
    read -r -p "${C_MAGENTA}Remote URL${C_RESET}: " url
    if [ -n "${url}" ]; then
      break
    fi
    say "URL cannot be empty."
  done

  if git remote add "${name}" "${url}"; then
    shout_success "Remote added: ${name}"
    SELECTED_REMOTE="${name}"
    return 0
  fi

  shout_error "💥 Failed to add remote."
  return 1
}

select_remote_for_push() {
  local remotes=()
  local remote
  local idx=0
  local i
  local total
  local prompt="🛰️ Choose remote (use up/down and Enter; origin is preselected when it exists):"

  SELECTED_REMOTE=""

  while IFS= read -r remote; do
    if [ -n "${remote}" ]; then
      remotes+=("${remote}")
    fi
  done < <(git remote)

  total="${#remotes[@]}"
  if [ "${total}" -eq 0 ]; then
    if add_remote_interactive; then
      return 0
    fi
    return 1
  fi

  if [ ! -t 0 ]; then
    for i in "${!remotes[@]}"; do
      if [ "${remotes[$i]}" = "origin" ]; then
        SELECTED_REMOTE="origin"
        return 0
      fi
    done
    SELECTED_REMOTE="${remotes[0]}"
    return 0
  fi

  for i in "${!remotes[@]}"; do
    if [ "${remotes[$i]}" = "origin" ]; then
      idx="${i}"
      break
    fi
  done

  if [ "${total}" -eq 1 ]; then
    SELECTED_REMOTE="${remotes[0]}"
    return 0
  fi

  MENU_LABELS=( "${remotes[@]}" )
  MENU_VALUES=( "${remotes[@]}" )
  if arrow_menu_interactive "${prompt}" "${idx}" "🛰️ Selected remote: %s" "🛑 Remote selection cancelled."; then
    SELECTED_REMOTE="${MENU_SELECTED}"
    return 0
  fi
  return 1
}

# Echoes the destination phrase after "Push fucking tag <tag> …" (no leading "to ").
push_tag_destination_phrase() {
  local remotes=()
  local r
  while IFS= read -r r; do
    if [ -n "${r}" ]; then
      remotes+=("${r}")
    fi
  done < <(git remote)

  local n="${#remotes[@]}"
  if [ "${n}" -eq 0 ]; then
    echo "to a remote? (none yet — you can add one)"
  elif [ "${n}" -eq 1 ]; then
    echo "to ${remotes[0]}"
  else
    for r in "${remotes[@]}"; do
      if [ "${r}" = "origin" ]; then
        echo "to origin or another remote"
        return 0
      fi
    done
    echo "to one of your remotes (choose next)"
  fi
}

push_tag_if_wanted() {
  local tag_name="$1"
  local remote_name
  local push_prompt

  push_prompt="Push fucking tag ${tag_name} $(push_tag_destination_phrase)"
  if ! prompt_yes_no "${push_prompt}"; then
    return 0
  fi

  if ! select_remote_for_push; then
    shout_error "💥 Error: no remote configured. Tag stays local."
    return 0
  fi

  remote_name="${SELECTED_REMOTE}"

  if git push "${remote_name}" "${tag_name}"; then
    shout_success "🌍 Fucking tag pushed to ${remote_name}: ${tag_name}"
    return 0
  fi

  shout_error "💥 Error: failed to push tag ${tag_name} to ${remote_name}."
  say "🧷 Local tag still exists: ${tag_name}"
  return 0
}

create_first_commit_if_needed() {
  local commit_message

  if git rev-parse --verify HEAD >/dev/null 2>&1; then
    return 0
  fi

  say "🧨 This repository has no commits yet."
  if ! prompt_yes_no "Create the first fucking commit now"; then
    return 1
  fi

  read -r -p "${C_MAGENTA}📝 Commit message${C_RESET} [Initial commit]: " commit_message
  commit_message="${commit_message:-Initial commit}"

  if ! git config --get user.name >/dev/null 2>&1 || ! git config --get user.email >/dev/null 2>&1; then
    shout_error "💥 Error: git user.name/email is missing. Configure identity before first commit."
    return 1
  fi

  if ! prompt_yes_no "Stage all current files for the first fucking commit"; then
    shout_error "💥 Error: first commit cancelled. No files staged."
    return 1
  fi

  git add -A
  if ! git commit --allow-empty -m "${commit_message}" >/dev/null 2>&1; then
    shout_error "💥 Error: first commit failed."
    return 1
  fi
  shout_success "⚔️ First fucking commit created: ${commit_message}"
  return 0
}

prompt_yes_no() {
  local prompt="$1"
  local answer

  while true; do
    read -r -p "${C_MAGENTA}🤘 ${prompt} [y/n]${C_RESET}: " answer
    case "${answer}" in
      y|Y) return 0 ;;
      n|N) return 1 ;;
      *) say "🤘 Only y or n survives this fucking solo." ;;
    esac
  done
}

select_bump_type() {
  local options=("major" "minor" "patch")
  local labels=("💀 MAJOR - fucking apocalyptic leap" "⚡ MINOR - fucking thunderous rise" "🔥 PATCH - fucking razor edge tweak")
  local prompt="🎛️ Choose your fucking release mode (use up/down and Enter):"
  local key

  SELECTED_BUMP_TYPE=""

  if [ ! -t 0 ]; then
    say "${prompt}"
    PS3="🎚️ Choice: "
    select key in "${labels[@]}"; do
      if [ -n "${key:-}" ]; then
        SELECTED_BUMP_TYPE="${options[$((REPLY - 1))]}"
        return 0
      fi
      say "🔥 Invalid fucking selection."
    done
  fi

  MENU_LABELS=( "${labels[@]}" )
  MENU_VALUES=( "${options[@]}" )
  if arrow_menu_interactive "${prompt}" 0 "🔥 Selected: %s" "🛑 Selection fucking cancelled."; then
    SELECTED_BUMP_TYPE="${MENU_SELECTED}"
    return 0
  fi
  return 1
}

if ! command -v git >/dev/null 2>&1; then
  shout_error "💥 Error: git is not fucking installed."
  exit 1
fi

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  shout_error "💥 Error: not inside a fucking git repository."
  exit 1
fi

banner

if ! create_first_commit_if_needed; then
  shout_error "💥 Error: first fucking commit is required before tagging."
  exit 1
fi

latest_tag="$(get_latest_semver_tag || true)"

if [ -z "${latest_tag}" ]; then
  if [ -n "$(git tag | sed -n '1p')" ]; then
    say "📭 Found tags, but no semver tags like v1.2.3 or 1.2.3."
  else
    say "📭 No fucking tags found in this repository."
  fi

  if ! prompt_yes_no "No riffs yet. Forge the first fucking tag"; then
    exit 0
  fi

  if ! select_bump_type; then
    exit 0
  fi
  bump_type="${SELECTED_BUMP_TYPE}"
  case "${bump_type}" in
    major) new_tag="1.0.0" ;;
    minor) new_tag="0.1.0" ;;
    patch) new_tag="0.0.1" ;;
  esac

  say "🔥 First fucking tag queued: ${new_tag}"
  if ! prompt_yes_no "Release ${new_tag} now and unleash the fucking fury"; then
    exit 0
  fi

  read_tag_message
  create_git_tag "${new_tag}" "${TAG_MESSAGE}"
  if [ -n "${TAG_MESSAGE}" ]; then
    shout_success "🚀 Fucking annotated tag unleashed: ${new_tag}"
  else
    shout_success "🚀 Fucking tag unleashed: ${new_tag}"
  fi
  push_tag_if_wanted "${new_tag}"
  say_release_goodbye
  exit 0
fi

say "🎤 Latest tag on stage: ${latest_tag}"

if ! prompt_yes_no "Bump this tag and release the fucking fury"; then
  exit 0
fi

tag_prefix=""
tag_version="${latest_tag}"
if [[ "${latest_tag}" =~ ^([^0-9]*)([0-9]+\.[0-9]+\.[0-9]+)$ ]]; then
  tag_prefix="${BASH_REMATCH[1]}"
  tag_version="${BASH_REMATCH[2]}"
fi

if [[ ! "${tag_version}" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
  shout_error "💥 Error: latest tag is not semver-like (expected e.g. 1.2.3 or v1.2.3). Fix this fucking tag."
  exit 1
fi

IFS='.' read -r major minor patch <<< "${tag_version}"

base_major="${major}"
base_minor="${minor}"
base_patch="${patch}"

while true; do
  if ! select_bump_type; then
    exit 0
  fi
  bump_type="${SELECTED_BUMP_TYPE}"
  major="${base_major}"
  minor="${base_minor}"
  patch="${base_patch}"

  case "${bump_type}" in
    major)
      major=$((major + 1))
      minor=0
      patch=0
      ;;
    minor)
      minor=$((minor + 1))
      patch=0
      ;;
    patch)
      patch=$((patch + 1))
      ;;
  esac

  new_tag="${tag_prefix}${major}.${minor}.${patch}"
  if git rev-parse "${new_tag}" >/dev/null 2>&1; then
    shout_error "💥 Tag ${new_tag} already exists. Choose another fucking bump."
    continue
  fi

  say "🛠️ Next fucking tag forged: ${new_tag}"
  break
done

if ! prompt_yes_no "Release ${new_tag} now and unleash the fucking fury"; then
  exit 0
fi

read_tag_message
create_git_tag "${new_tag}" "${TAG_MESSAGE}"
if [ -n "${TAG_MESSAGE}" ]; then
  shout_success "🚀 Fucking annotated tag unleashed: ${new_tag}"
else
  shout_success "🚀 Fucking tag unleashed: ${new_tag}"
fi
push_tag_if_wanted "${new_tag}"
say_release_goodbye
